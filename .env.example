# --- Postgres ---
POSTGRES_USER=lectures
POSTGRES_PASSWORD=lectures
POSTGRES_DB=lectures
DATABASE_URL=postgresql+asyncpg://lectures:lectures@postgres:5432/lectures

# --- Redis (arq broker) ---
REDIS_URL=redis://redis:6379/0

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lectures
MINIO_SECURE=false
# Public endpoint the browser uses for presigned URLs (host-reachable)
MINIO_PUBLIC_ENDPOINT=localhost:9000

# --- vLLM (existing k8s deployment) ---
VLLM_BASE_URL=http://192.168.1.116:30800/v1
VLLM_MODEL=qwen3-14b-awq

# --- Whisper ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANGUAGE=ru
